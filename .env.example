# Firebase Configuration
# Get these values from: Firebase Console → Project Settings → Your apps → Web app config

VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
VITE_FIREBASE_APP_ID=1:your_app_id

# Example (DO NOT use these - get your own from Firebase):
# VITE_FIREBASE_API_KEY=AIzaSyDemoKeyReplaceMeWithYourActualKey
# VITE_FIREBASE_AUTH_DOMAIN=smart-attendance-sece.firebaseapp.com
# VITE_FIREBASE_PROJECT_ID=smart-attendance-sece
# VITE_FIREBASE_STORAGE_BUCKET=smart-attendance-sece.appspot.com
# VITE_FIREBASE_MESSAGING_SENDER_ID=123456789012
# VITE_FIREBASE_APP_ID=1:123456789012:web:abcdef1234567890abcdef
